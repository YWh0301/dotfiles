# Maintainer: pingzi <pingzi@archlinux>
# Contributor: Sean P. Kane <spkane@gmail.com>

pkgname=freecad-robust-mcp
pkgver=0.6.2
pkgrel=1
pkgdesc='Robust MCP Server for FreeCAD — 150+ tools for AI-assisted parametric 3D CAD modeling, sketching, PartDesign, booleans, export, macros, and more via Model Context Protocol'
arch=('any')
url='https://github.com/rickenbroc/freecad-addon-robust-mcp-server'
license=('MIT')
depends=(
  'freecad>=1.0'
  'python>=3.11'
  'python-mcp>=1.25'
  'python-pydantic>=2.10'
  'python-pydantic-settings>=2.7'
)
makedepends=(
  'python-build'
  'python-hatchling'
  'python-installer'
)
# python-pyside6 is already pulled in by freecad dependency
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/rickenbroc/freecad-addon-robust-mcp-server/archive/refs/tags/robust-mcp-server-v${pkgver}.tar.gz")
sha256sums=('535838576f46a2558b55fdf4a55de938bc5400ffd2ba6867e693b22c03974a4a')
options=('!strip' '!debug')

_srcname="freecad-addon-robust-mcp-server-robust-mcp-server-v${pkgver}"

build() {
  cd "${srcdir}/${_srcname}"

  # The upstream pyproject.toml uses hatch-vcs to derive version from git
  # tags, which isn't available in a tarball archive. Patch it to use a
  # static version string and drop the hatch-vcs build dependency.
  python3 << PYEOF
import re, pathlib

tp = pathlib.Path('pyproject.toml')
text = tp.read_text()

# 1. Replace dynamic version with static
pkgver = "${pkgver}"
text = re.sub(
    r'dynamic = \[\s*"version"\s*\]',
    f'version = "{pkgver}"',
    text,
)

# 2. Remove hatch-vcs from build-system.requires
simple = re.sub(r'[,\s]*"hatch-vcs"[,\s]*', ', ', text)
text = simple

# 3. Remove [tool.hatch.version] section (incl. raw-options)
text = re.sub(
    r'\[tool\.hatch\.version\].*?(?=\n\[|\Z)',
    '',
    text,
    flags=re.DOTALL,
)

# 4. Remove [tool.hatch.build.hooks.vcs] section
text = re.sub(
    r'\[tool\.hatch\.build\.hooks\.vcs\].*?(?=\n\[|\Z)',
    '',
    text,
    flags=re.DOTALL,
)

tp.write_text(text)
print('patched: static version, removed hatch-vcs')
PYEOF

  # Manually write _version.py so the package reports version at runtime
  cat > src/freecad_mcp/_version.py << VERSIONEOF
# Auto-generated by PKGBUILD
__version__ = "${pkgver}"
VERSIONEOF

  python -m build --wheel --no-isolation
}

package() {
  cd "${srcdir}/${_srcname}"

  # Install the Python package (provides the freecad-mcp CLI entry point)
  python -m installer --destdir="${pkgdir}" dist/*.whl

  # Replace the pip-generated entry point with a shell wrapper that sets
  # PYTHONPATH so FreeCAD's Python libraries (at /usr/lib/freecad/lib/)
  # are importable. Without this, 'import FreeCAD' fails at startup.
  local _cli="${pkgdir}/usr/bin/freecad-mcp"
  rm -f "${_cli}"
  cat > "${_cli}" << 'LAUNCHER'
#!/bin/bash
# freecad-mcp launcher — sets PYTHONPATH for FreeCAD Python libs
export PYTHONPATH="${PYTHONPATH:+${PYTHONPATH}:}/usr/lib/freecad/lib"
exec /usr/bin/python3 -m freecad_mcp.server "$@"
LAUNCHER
  chmod 755 "${_cli}"

  # Install the FreeCAD workbench addon
  local _addon_dir="${pkgdir}/usr/share/freecad/Mod/RobustMCPBridge"
  install -d "${_addon_dir}"
  cp -a addon/FreecadRobustMCPBridge/* "${_addon_dir}/"

  # Remove __pycache__ and .pyc artifacts
  find "${_addon_dir}" -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true
  find "${_addon_dir}" -name '*.pyc' -delete

  # Install package.xml for FreeCAD Addon Manager discovery
  install -Dm644 package.xml "${_addon_dir}/package.xml"

  # Install license
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
