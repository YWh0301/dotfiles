# Maintainer: pingzi <pingzi@archlinux>
pkgname=pi-ext-ocr
pkgver=1.4.0
pkgrel=1
pkgdesc='Multi-backend OCR for Pi coding agent — MinerU (free cloud), Ollama (local GPU), Tesseract, Pix2Text. Extract text, formulas, tables from images and PDFs.'
arch=('any')
url='https://github.com/astronautJack/pi-ocr'
license=('MIT')
source=(
  "${pkgname}-${pkgver}.tgz::https://registry.npmjs.org/pi-ocr/-/pi-ocr-${pkgver}.tgz"
)
sha256sums=('de5d68bf02f22989e33e8d7b3074b740fb670f152a4cef79f40b35e8c52e5ae1')
install=pi-ext.install
options=('!strip' '!debug')
optdepends=(
  'pi-coding-agent: Pi coding agent itself'
  'pi-coding-agent-git: Pi coding agent development version'
  'ollama: local GPU OCR backend (glm-ocr model)'
  'tesseract: classic OCR engine'
  'python-pix2text: local Python OCR with formula recognition'
  'poppler: pdftoppm for multi-page PDF support in Ollama backend'
)

package() {
  install -d "${pkgdir}/usr/share/pi/extensions/pi-ocr"
  cp -a "${srcdir}/package/." "${pkgdir}/usr/share/pi/extensions/pi-ocr/"

  install -Dm644 "${srcdir}/package/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
