#!/bin/sh
{{- $userConfig := includeTemplate "user-config.toml" . | fromToml }}

if [ ! -f "${HOME}/.ssh/id_ed25519" ]; then
    mkdir -p "${HOME}/.ssh"
    echo "Generating new SSH key..."
    if ssh-keygen -t ed25519 -C "{{ $userConfig.ssh.key_comment }}" -f "${HOME}/.ssh/id_ed25519" -N "" -q; then
        echo "SSH key generated successfully."
    else
        echo "Failed to generate SSH key."
    fi
fi
