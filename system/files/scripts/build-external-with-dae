#!/usr/bin/bash
# Build one reviewed PKGBUILD without allowing external network failure to abort
# the signed base-system transaction. The caller sets makepkg cache variables
# and the current directory.
set +e

package=${1:?package name is required}
dae_config=/etc/dae/config.dae
failure_file=${STATUSDIR:?STATUSDIR is required}/${package}.failure

/usr/bin/install -d "${BUILDDIR}" "${LOGDEST}" "${PKGDEST}" "${SRCDEST}" "${STATUSDIR}"
record_failure() {
    local message=$1
    printf '%s\n' "${message}" > "${failure_file}.tmp"
    /usr/bin/mv -f "${failure_file}.tmp" "${failure_file}"
    printf '%s\n' "WARNING: ${package}: ${message}; continuing deployment" >&2
    exit 1
}
record_success() {
    /usr/bin/rm -f "${failure_file}"
    exit 0
}

for dependency in ${REQUIRED_EXTERNAL_DEPENDENCIES:-}; do
    if [[ -s ${STATUSDIR}/${dependency}.failure ]]; then
        record_failure "blocked by failed reviewed external dependency: ${dependency}"
    fi
done

if ! sudo -n -v; then
    record_failure "sudo timestamp unavailable before build"
fi

install_cached_package() {
    local file
    local -a files
    mapfile -t files < <(/usr/bin/makepkg --config "${MAKEPKG_CONFIG}" --packagelist)
    (( ${#files[@]} )) || return 1
    for file in "${files[@]}"; do
        [[ -f ${file} ]] || return 1
    done
    sudo -n /usr/bin/pacman -U --needed --noconfirm -- "${files[@]}"
}

build_package() {
    /usr/bin/makepkg \
        --config "${MAKEPKG_CONFIG}" \
        --syncdeps \
        --install \
        --needed \
        --noconfirm \
        --cleanbuild \
        --clean
}

install_cached_package && record_success
build_package
status=$?
if (( status == 0 )) || install_cached_package; then
    record_success
fi

printf '%s\n' "WARNING: direct/selected-proxy build failed for ${package}; trying DAE fallback" >&2
unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY
if ! sudo -n /usr/bin/dae validate -c "${dae_config}" >/dev/null 2>&1; then
    record_failure "direct build failed and DAE is unavailable or invalid"
fi

started_dae=0
dae_pid=
dae_launcher=
cleanup_dae() {
    if (( started_dae == 1 )); then
        if [[ -n ${dae_pid} ]]; then
            sudo -n /usr/bin/kill "${dae_pid}" >/dev/null 2>&1 || true
        elif [[ -n ${dae_launcher} ]]; then
            /usr/bin/kill "${dae_launcher}" >/dev/null 2>&1 || true
        fi
        [[ -z ${dae_launcher} ]] || wait "${dae_launcher}" >/dev/null 2>&1 || true
        sudo -n /usr/bin/rm -f /run/dae.pid
        started_dae=0
    fi
}
trap cleanup_dae EXIT INT TERM

if ! sudo -n /usr/bin/systemctl is-active --quiet dae.service 2>/dev/null; then
    sudo -n /usr/bin/rm -f /run/dae.pid
    sudo -n /usr/bin/dae run -c "${dae_config}" --disable-sudo \
        --logfile /tmp/personal-system-dae.log >/dev/null 2>&1 &
    dae_launcher=$!
    started_dae=1
    for _ in $(seq 1 20); do
        /usr/bin/curl --fail --silent --location --head --max-time 3 \
            https://aur.archlinux.org/ >/dev/null 2>&1 && break
        sleep 1
    done
    if sudo -n /usr/bin/test -s /run/dae.pid; then
        dae_pid=$(sudo -n /usr/bin/cat /run/dae.pid)
    fi
fi

build_package
status=$?
if (( status != 0 )) && install_cached_package; then
    status=0
fi
cleanup_dae
trap - EXIT INT TERM
if (( status != 0 )); then
    record_failure "direct build and DAE fallback both failed"
fi
record_success
