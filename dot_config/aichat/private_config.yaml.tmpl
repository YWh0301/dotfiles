{{- $userConfig := includeTemplate "user-config.toml" . | fromToml -}}

# ---- llm ----
model: deepseek:deepseek-v4-flash
temperature: null
top_p: null

# ---- behavior ----
stream: true
save: true
keybindings: vi
editor: nvim
wrap: no
wrap_code: false

# ---- prelude ----
repl_prelude: temp:answer
cmd_prelude: null

# ---- session ----
save_session: null
compress_threshold: 327680
summarize_prompt: 'Summarize the discussion briefly in 200 words or less to use as a prompt for future context.'
summary_prompt: 'This is a summary of the chat history as a recap: '

# Only the two providers currently used are defined here. Their shared API
# keys live in user.toml; provider/model metadata remains application-local.
clients:
  - type: openai-compatible
    name: deepseek
    api_base: https://api.deepseek.com
    api_key: {{ $userConfig.api_keys.deepseek | quote }}
    models:
      - name: deepseek-v4-flash
        max_input_tokens: 1000000
        max_output_tokens: 384000
        input_price: 1
        output_price: 2
        supports_function_calling: true

  - type: openai-compatible
    name: opencode-go
    api_base: https://opencode.ai/zen/go/v1
    api_key: {{ $userConfig.api_keys.opencode_go | quote }}
    models:
      - name: deepseek-v4-flash
        max_input_tokens: 1000000
        max_output_tokens: 384000
        input_price: 0
        output_price: 0
        supports_function_calling: true
