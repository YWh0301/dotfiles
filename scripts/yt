#!/bin/bash
# yt — 透明 yazi 开启器

cwd="$PWD"

if [ -z "${SSH_CLIENT:-}" ]; then
    kitty -e zsh -i -c "y '${cwd}'; zsh"
    exit 0
fi

# ─── SSH 会话：通过 kitty @ launch 让守护进程开新窗口 ───
client_ip="${SSH_CLIENT%% *}"
server_ip="$(echo "$SSH_CONNECTION" | awk '{print $3}')"
remote_host="$(hostname -s)"

path_hash="$(echo "$cwd" | md5sum | cut -c1-8)"
local_mount_point="/tmp/remote-${remote_host}-${path_hash}"

local_commands="
xdr=\"\${XDG_RUNTIME_DIR:-/run/user/\$(id -u)}\"
kitty_socket=\$(ls \"\$xdr\"/kitty.sock-* 2>/dev/null | head -1)
if [ -n \"\$kitty_socket\" ]; then
    kitty @ --to \"unix:\${kitty_socket}\" launch --type=os-window --no-response env RMOUNT='${local_mount_point}' RCWD='${cwd}' RSERVER='${server_ip}' zsh -i -c 'mkdir -p \"\$RMOUNT\" && ( mountpoint -q \"\$RMOUNT\" || sshfs pingzi@\$RSERVER:\"\$RCWD\" \"\$RMOUNT\" -o reconnect,ServerAliveInterval=15 ) && y \"\$RMOUNT\"; exec zsh'
fi
"

if ssh -o ConnectTimeout=3 -o BatchMode=yes "pingzi@${client_ip}" true 2>/dev/null; then
    ssh -o ConnectTimeout=5 "pingzi@${client_ip}" "$local_commands"
fi
