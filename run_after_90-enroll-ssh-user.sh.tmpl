#!/bin/sh
set -eu
{{- $userConfig := includeTemplate "user-config.toml" . | fromToml }}

ssh_dir="${HOME}/.ssh"
private_key="${ssh_dir}/id_ed25519"
public_key="${private_key}.pub"
certificate="${ssh_dir}/id_ed25519-cert.pub"
ca_dir="${HOME}/.local/share/ssh-ca"
ca_private="${ca_dir}/user_ca"
ca_public="${ca_private}.pub"
principal="$(id -un)"
key_id="{{ $userConfig.identity.name }}@{{ $userConfig.machine.hostname }}-$(date -u +%Y%m%d)"
certificate_enabled={{ if $userConfig.features.ssh_user_cert }}true{{ else }}false{{ end }}

mkdir -p "${ssh_dir}"
chmod 700 "${ssh_dir}"

# The ordinary key pair always exists and is never removed when certificate
# enrollment is toggled.
if [ ! -f "${private_key}" ]; then
    /usr/bin/ssh-keygen -t ed25519 -f "${private_key}" \
        -C "{{ $userConfig.identity.name }}@{{ $userConfig.machine.hostname }}" -N ""
fi
if [ ! -f "${public_key}" ]; then
    /usr/bin/ssh-keygen -y -f "${private_key}" > "${public_key}"
fi
chmod 600 "${private_key}"
chmod 644 "${public_key}"

if [ "${certificate_enabled}" != true ]; then
    rm -f "${certificate}"
    exit 0
fi

if [ ! -f "${ca_private}" ] || [ ! -f "${ca_public}" ]; then
    cat >&2 <<EOF
SSH certificate enrollment is enabled, but the User CA is not installed.
Run the explicit CA creation/import ceremony first:

  ${HOME}/.local/share/chezmoi/scripts/create-ssh-user-ca
EOF
    exit 1
fi

public_fingerprint="$(/usr/bin/ssh-keygen -lf "${public_key}" | awk '{print $2}')"
ca_fingerprint="$(/usr/bin/ssh-keygen -lf "${ca_public}" | awk '{print $2}')"

# Return early when the existing certificate matches this key, CA, principal,
# and has more than 30 days of validity remaining.
if [ -f "${certificate}" ] && /usr/bin/python - "${certificate}" "${public_fingerprint}" "${ca_fingerprint}" "${principal}" <<'PY'
from datetime import datetime, timedelta
import re
import subprocess
import sys

certificate, public_fp, ca_fp, principal = sys.argv[1:]
try:
    text = subprocess.check_output(
        ["/usr/bin/ssh-keygen", "-L", "-f", certificate],
        text=True,
        stderr=subprocess.DEVNULL,
    )
    public_match = re.search(r"^\s*Public key:.*(SHA256:[^ ]+)$", text, re.MULTILINE)
    ca_match = re.search(r"^\s*Signing CA:.*(SHA256:[^ ]+)", text, re.MULTILINE)
    valid_match = re.search(r"^\s*Valid: from ([^ ]+) to ([^ ]+)$", text, re.MULTILINE)
    principals_match = re.search(
        r"^\s*Principals:\s*$\n(?P<body>.*?)(?=^\s*Critical Options:)",
        text,
        re.MULTILINE | re.DOTALL,
    )
    principals = {
        line.strip() for line in principals_match.group("body").splitlines() if line.strip()
    }
    expires = datetime.fromisoformat(valid_match.group(2))
    valid = (
        public_match.group(1) == public_fp
        and ca_match.group(1) == ca_fp
        and principal in principals
        and expires > datetime.now() + timedelta(days=30)
    )
except Exception:
    valid = False
raise SystemExit(0 if valid else 1)
PY
then
    exit 0
fi

if ! : < /dev/tty 2>/dev/null; then
    echo "SSH certificate enrollment requires an interactive terminal; run chezmoi apply." >&2
    exit 1
fi

cat >/dev/tty <<EOF
SSH user certificate enrollment

  Public key: ${public_fingerprint}
  Signing CA: ${ca_fingerprint}
  Principal:  ${principal}
  Key ID:     ${key_id}
  Validity:   -5m:+52w

EOF
printf 'Issue this certificate? [y/N] ' >/dev/tty
IFS= read -r answer </dev/tty
case "${answer}" in
    y|Y|yes|YES) ;;
    *) echo "SSH certificate enrollment cancelled." >&2; exit 1 ;;
esac

temporary_dir="$(mktemp -d)"
trap 'rm -rf "${temporary_dir}"' EXIT HUP INT TERM
cp "${public_key}" "${temporary_dir}/id_ed25519.pub"
/usr/bin/ssh-keygen \
    -s "${ca_private}" \
    -I "${key_id}" \
    -n "${principal}" \
    -V "-5m:+52w" \
    -z "$(date +%s%N)" \
    "${temporary_dir}/id_ed25519.pub"
install -m 644 "${temporary_dir}/id_ed25519-cert.pub" "${certificate}"
/usr/bin/ssh-keygen -L -f "${certificate}"
