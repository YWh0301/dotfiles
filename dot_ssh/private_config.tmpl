{{- $userConfig := includeTemplate "user-config.toml" . | fromToml -}}
{{- range $userConfig.ssh.hosts -}}
Host {{ .name }}
    HostName {{ .hostname }}
    User {{ .user }}
    Port {{ .port }}
    IdentityFile {{ .identity_file }}

{{ end -}}
Host github.com
    Hostname ssh.github.com
    Port 443
{{- if eq $userConfig.proxy.backend "flclash" }}
    ProxyCommand socat - PROXY:127.0.0.1:%h:%p,proxyport={{ $userConfig.proxy.flclash_http_port }}
{{- end }}
